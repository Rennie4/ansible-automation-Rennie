security_options:

  # 1) Accounts
  accounts:
    # Limit local account use of blank passwords to console logon only = Enabled
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Control\Lsa
      name: LimitBlankPasswordUse
      type: dword
      data: 1

    # Administrator account status = Disabled
    - provider: secedit
      section: "System Access"
      policy_name: "Accounts: Administrator account status"
      value: "Disabled"

    # Guest account status = Disabled
    - provider: secedit
      section: "System Access"
      policy_name: "Accounts: Guest account status"
      value: "Disabled"

    # Rename Administrator (example value)
    - provider: secedit
      section: "System Access"
      policy_name: "Accounts: Rename administrator account"
      value: "LocalAdmin-RG"

    # Rename Guest (example value)
    - provider: secedit
      section: "System Access"
      policy_name: "Accounts: Rename guest account"
      value: "Guest-RG"

  # 2) Interactive logon
  interactive_logon:
    # Do not display last user name = Enabled
    - provider: registry
      path: HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System
      name: DontDisplayLastUserName
      type: dword
      data: 1

    # Require CTRL+ALT+DEL (DisableCAD = 0)
    - provider: registry
      path: HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System
      name: DisableCAD
      type: dword
      data: 0

  # 3) Network security
  network_security:
    # LAN Manager authentication level = Send NTLMv2 only; Refuse LM & NTLM (5)
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Control\Lsa
      name: LmCompatibilityLevel
      type: dword
      data: 5

    # Minimum session security for NTLM SSP clients = Require NTLMv2 + 128-bit (0x82000 = 532480)
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Control\Lsa\MSV1_0
      name: NTLMMinClientSec
      type: dword
      data: 532480

    # Minimum session security for NTLM SSP servers = Require NTLMv2 + 128-bit (0x82000 = 532480)
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Control\Lsa\MSV1_0
      name: NTLMMinServerSec
      type: dword
      data: 532480

  # 4) Microsoft network client
  microsoft_network_client:
    # Digitally sign communications (always) = Enabled
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Services\LanmanWorkstation\Parameters
      name: RequireSecuritySignature
      type: dword
      data: 1

    # Digitally sign communications (if client agrees) = Enabled
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Services\LanmanWorkstation\Parameters
      name: EnableSecuritySignature
      type: dword
      data: 1

  # 5) Microsoft network server
  microsoft_network_server:
    # Digitally sign communications (always) = Enabled
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Services\LanmanServer\Parameters
      name: RequireSecuritySignature
      type: dword
      data: 1

    # Digitally sign communications (if client agrees) = Enabled
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Services\LanmanServer\Parameters
      name: EnableSecuritySignature
      type: dword
      data: 1

    # Disable SMBv1 server component
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Services\LanmanServer\Parameters
      name: SMB1
      type: dword
      data: 0

  # 6) Domain member
  domain_member:
    # Secure channel signing & sealing / strong keys
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Services\Netlogon\Parameters
      name: RequireSignOrSeal
      type: dword
      data: 1
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Services\Netlogon\Parameters
      name: SealSecureChannel
      type: dword
      data: 1
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Services\Netlogon\Parameters
      name: SignSecureChannel
      type: dword
      data: 1
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Services\Netlogon\Parameters
      name: RequireStrongKey
      type: dword
      data: 1
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Services\Netlogon\Parameters
      name: DisablePasswordChange
      type: dword
      data: 0

  # 7) Devices
  devices:
    # Prevent users from installing printer drivers = Enabled
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Control\Print\Providers\LanMan Print Services\Servers
      name: AddPrinterDrivers
      type: dword
      data: 1

  # 8) UAC
  uac:
    # Run all administrators in Admin Approval Mode = Enabled
    - provider: registry
      path: HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System
      name: EnableLUA
      type: dword
      data: 1

    # Admin Approval Mode for built-in Administrator = Enabled
    - provider: registry
      path: HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System
      name: FilterAdministratorToken
      type: dword
      data: 1

    # Behavior of the elevation prompt for admins = Prompt for consent on the secure desktop (2)
    - provider: registry
      path: HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System
      name: ConsentPromptBehaviorAdmin
      type: dword
      data: 2

    # Switch to the secure desktop when prompting = Enabled
    - provider: registry
      path: HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System
      name: PromptOnSecureDesktop
      type: dword
      data: 1

    # Detect application installations and prompt for elevation = Enabled
    - provider: registry
      path: HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System
      name: EnableInstallerDetection
      type: dword
      data: 1

  # 9) LDAP client signing
  ldap_client_signing:
    # LDAP client signing requirements = Require signing (2)
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Services\LDAP
      name: LDAPClientIntegrity
      type: dword
      data: 2

  # 10) Network access (anonymous restrictions / shares / named pipes)
  network_access:
    # Restrict anonymous access to Named Pipes and Shares = Enabled
    - provider: registry
      path: HKLM:\SYSTEM\CurrentControlSet\Services\LanmanServer\Parameters
      name: RestrictNullSessAccess
      type: dword
      data: 1
