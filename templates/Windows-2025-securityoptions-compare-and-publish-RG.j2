<!DOCTYPE html>
<html>
<head>
    <title>Security Options Audit: {{ inventory_hostname }}</title>
    <style>
        body { font-family: sans-serif; margin: 20px; color: #333; }
        .header { background-color: #1a365d; color: white; padding: 15px; border-radius: 5px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #cbd5e0; padding: 10px; text-align: left; }
        th { background-color: #edf2f7; color: #2d3748; }
        .meta { font-size: 0.85em; color: #718096; margin-top: 5px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Windows 2025 Security Audit (2.38 - 2.44)</h1>
        <div class="meta">
            Host: {{ inventory_hostname }} | Date: {{ ansible_date_time.iso8601 }}
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>CIS ID</th>
                <th>Security Setting</th>
                <th>Current State</th>
            </tr>
        </thead>
        <tbody>
            {% for key, value in audit.items() %}
            <tr>
                <td>{{ key.split('_')[0] }}</td>
                <td>{{ key.split('_')[1] | replace('Status', '') }}</td>
                <td><strong>{{ value }}</strong></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <p style="font-size: 0.8em; color: #a0aec0; margin-top: 30px;">
        * This report is generated dynamically. No hardcoded EBS or Volume IDs were used.
    </p>
</body>
</html>
