<!DOCTYPE html>
<html>
<head>
    <title>CIS Audit: {{ inventory_hostname }}</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, sans-serif; padding: 30px; background-color: #f8f9fa; }
        .container { background: white; padding: 25px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h1 { color: #003366; border-bottom: 2px solid #003366; padding-bottom: 10px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #dee2e6; padding: 12px; text-align: left; }
        th { background-color: #003366; color: white; }
        .pass { color: #28a745; font-weight: bold; }
        .fail { color: #dc3545; font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <h1>CIS Security Options Audit (2.38 - 2.44)</h1>
        <p><strong>Target Host:</strong> {{ inventory_hostname }}</p>
        <p><strong>Reference:</strong> CIS Benchmark for Microsoft Windows Server 2025 v1.0.0</p>
        <table>
            <thead>
                <tr>
                    <th>CIS ID</th>
                    <th>Current Value</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {% for key, value in audit.items() %}
                <tr>
                    <td>{{ key.split('_')[0] }}</td>
                    <td>{{ value }}</td>
                    <td>
                        {% set status = "pass" %}
                        {% if key == "2.38_GuestAccountStatus" and value == true %}{% set status = "fail" %}{% endif %}
                        {% if key == "2.39_LimitBlankPassword" and value == 0 %}{% set status = "fail" %}{% endif %}
                        {% if key == "2.41_ShutDownOnAuditFail" and value == 1 %}{% set status = "fail" %}{% endif %}
                        <span class="{{ status }}">{{ "COMPLIANT" if status == "pass" else "NON-COMPLIANT" }}</span>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</body>
</html>
