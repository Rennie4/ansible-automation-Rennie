<!DOCTYPE html>
<html>
<head>
    <title>CIS Audit: 2.38 - 2.44</title>
    <style>
        body { font-family: 'Segoe UI', Arial; padding: 20px; background-color: #f4f4f4; }
        .card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background-color: #004a99; color: white; }
        .pass { background-color: #d4edda; color: #155724; font-weight: bold; padding: 4px 8px; border-radius: 4px; }
        .fail { background-color: #f8d7da; color: #721c24; font-weight: bold; padding: 4px 8px; border-radius: 4px; }
    </style>
</head>
<body>
    <div class="card">
        <h2>CIS Windows Server 2025 Security Audit (2.38 - 2.44)</h2>
        <p><strong>Host:</strong> {{ inventory_hostname }} | <strong>Audit Time:</strong> {{ ansible_date_time.iso8601 }}</p>
        <table>
            <thead>
                <tr>
                    <th>CIS ID & Description</th>
                    <th>Current Value</th>
                    <th>Compliance</th>
                </tr>
            </thead>
            <tbody>
                {% for key, value in audit.items() %}
                <tr>
                    <td>{{ key.replace('_', ' ') }}</td>
                    <td>{{ value }}</td>
                    <td>
                        {# Simple logic for guest and blank password compliance #}
                        {% if (key == "2.38_GuestAccountStatus" and value == true) or (key == "2.39_LimitBlankPassword" and value == 0) %}
                            <span class="fail">NON-COMPLIANT</span>
                        {% else %}
                            <span class="pass">COMPLIANT</span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</body>
</html>
