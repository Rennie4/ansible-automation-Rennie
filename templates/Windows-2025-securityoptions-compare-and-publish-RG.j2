<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Security Audit: {{ inventory_hostname }}</title>
    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; padding: 20px; background-color: #f9f9f9; }
        .header { background: #232f3e; color: white; padding: 15px; border-radius: 5px; margin-bottom: 20px; }
        table { width: 100%; border-collapse: collapse; background: white; }
        th, td { border: 1px solid #dddddd; text-align: left; padding: 12px; }
        th { background-color: #f2f2f2; font-weight: bold; }
        .pass { color: #2d862d; font-weight: bold; }
        .fail { color: #d9534f; font-weight: bold; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Windows Server 2025 - Security Options Audit</h1>
        <p><strong>Host:</strong> {{ inventory_hostname }} | <strong>Date:</strong> {{ ansible_date_time.date }}</p>
    </div>

    <table>
        <thead>
            <tr>
                <th>Security Setting</th>
                <th>Current Value</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            {% for key, value in audit.items() %}
            <tr>
                <td>{{ key }}</td>
                <td>{{ value }}</td>
                <td>
                    {% if value == "Not Defined" or value == 0 %}
                    <span class="fail">ACTION REQUIRED</span>
                    {% else %}
                    <span class="pass">VERIFIED</span>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>
