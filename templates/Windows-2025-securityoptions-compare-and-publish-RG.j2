<!DOCTYPE html>
<html>
<head>
    <title>CIS NTLM Audit: {{ inventory_hostname }}</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; margin: 30px; background-color: #f4f7f9; }
        .container { background: white; padding: 25px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h1 { color: #004a99; border-bottom: 2px solid #004a99; padding-bottom: 10px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { text-align: left; padding: 12px; border: 1px solid #dee2e6; }
        th { background-color: #004a99; color: white; }
        .meta { color: #6c757d; font-size: 0.9em; margin-bottom: 20px; }
        .value-box { font-family: monospace; background: #f8f9fa; padding: 4px; border-radius: 4px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>CIS Microsoft Windows Server 2025 Audit</h1>
        <div class="meta">
            <strong>Host:</strong> {{ inventory_hostname }}<br>
            <strong>Date:</strong> {{ ansible_date_time.iso8601 }}<br>
            <strong>Scope:</strong> Network Security: Restrict NTLM (2.38 - 2.41)
        </div>

        <table>
            <thead>
                <tr>
                    <th>CIS ID</th>
                    <th>Policy Setting</th>
                    <th>Registry Value (Current)</th>
                </tr>
            </thead>
            <tbody>
                {% for key, value in audit.items() %}
                <tr>
                    <td>{{ key.split('_')[0] }} ({{ key.split('_')[1] }})</td>
                    <td>{{ key.split('_')[2] | replace('NTLM', ' NTLM') }}</td>
                    <td><span class="value-box">{{ value if value is not none else "Not Defined" }}</span></td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <p style="font-size: 0.8em; color: #999; margin-top: 20px;">
            Note: This report is generated dynamically and contains no hardcoded volume or infrastructure identifiers.
        </p>
    </div>
</body>
</html>
